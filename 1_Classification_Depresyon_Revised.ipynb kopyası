    "## 4. Preprocessing\n",
    "\n",
    "We apply:\n",
    "- **OneHotEncoder** on categorical features (drop first to avoid dummy variable trap)\n",
    "- **StandardScaler** on numeric features\n",
    "- **LabelEncoder** on the target variable"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 16,
   "id": "a1b2c3d4-0028-4e56-8901-abcdef012345",
   "metadata": {},
   "outputs": [],
   "source": [
    "from sklearn.model_selection import train_test_split\n",
    "from sklearn.compose import ColumnTransformer\n",
    "from sklearn.preprocessing import OneHotEncoder, StandardScaler, LabelEncoder"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 17,
   "id": "a1b2c3d4-0029-4e56-8901-abcdef012345",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Train size: (7500, 13), Test size: (2500, 13)\n"
     ]
    }
   ],
   "source": [
    "X = df.drop('mental_health_risk', axis=1)\n",
    "y = df['mental_health_risk']\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X, y, test_size=0.25, random_state=42\n",
    ")\n",
    "\n",
    "print(f\"Train size: {X_train.shape}, Test size: {X_test.shape}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 18,
   "id": "a1b2c3d4-0030-4e56-8901-abcdef012345",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Processed train shape: (7500, 18)\n",
      "Processed test shape: (2500, 18)\n"
     ]
    }
   ],
   "source": [
    "# NOTE: 'cat' transformer applies OneHotEncoder to CATEGORICAL columns\n",
    "#       'num' transformer applies StandardScaler to NUMERIC columns\n",
    "preprocessor = ColumnTransformer(\n",
    "    transformers=[\n",
    "        ('cat', OneHotEncoder(drop='first', handle_unknown='ignore'), categorical_cols),\n",
    "        ('num', StandardScaler(), numeric_cols)\n",
    "    ],\n",
    "    remainder='passthrough'\n",
    ")\n",
    "\n",
    "X_train_clean = preprocessor.fit_transform(X_train)\n",
    "X_test_clean = preprocessor.transform(X_test)\n",
    "\n",
    "print(f\"Processed train shape: {X_train_clean.shape}\")\n",
    "print(f\"Processed test shape: {X_test_clean.shape}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 19,
   "id": "a1b2c3d4-0031-4e56-8901-abcdef012345",
